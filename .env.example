# Application
APP_NAME=NexBuy Investment Committee
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database (SQLite local / PostgreSQL production)
DATABASE_URL=sqlite+aiosqlite:///./data/nexbuy.db
# DATABASE_URL=postgresql+asyncpg://nexbuy:nexbuy@localhost:5432/nexbuy

# Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Market Data Providers (fallback chain: Polygon → Alpha Vantage → YFinance)
YFINANCE_ENABLED=true
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_API_BASE_URL=https://api.massive.com
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
POLYGON_DAILY_LIMIT=1000
POLYGON_PER_MINUTE_LIMIT=5
ALPHA_VANTAGE_DAILY_LIMIT=25
TRADINGVIEW_ENABLED=false
TRADINGVIEW_API_KEY=
# FRED (Federal Reserve Economic Data) - https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
NEWS_API_KEY=

# LLM executive narratives (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Acceso multi-dispositivo (celular + PC) — elige una contraseña larga
DASHBOARD_ACCESS_TOKEN=elige_un_token_secreto_largo
# URL pública tras desplegar (opcional): https://tu-usuario-nexbuy-ceo.hf.space
PUBLIC_BASE_URL=

# Scheduler (US Eastern market hours)
MARKET_TIMEZONE=America/New_York
REPORT_TIMES=08:30,11:30,15:00,17:30

# Investment Director
AGENT_WEIGHTS_AUTO_CALIBRATE=true
MAX_CONCENTRATION_PCT=25.0

# Automation (Phase 3)
SCHEDULER_ENABLED=true
WATCHLIST_SCAN_INTERVAL_MINUTES=30
MEMORY_EVALUATION_DAYS=90
ALERT_COOLDOWN_HOURS=24

# Retry
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=1.5
