# Application
APP_NAME=NexBuy Investment Committee
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
# Local / Hobby sin Postgres (EFÍMERO en FastAPI Cloud — se borra en redeploy):
DATABASE_URL=sqlite+aiosqlite:///./data/nexbuy.db
# Persistente (recomendado): Neon free https://console.neon.tech
# Pega la connection string; se normaliza a postgresql+asyncpg automáticamente
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Cache en memoria (no requiere Redis)
REDIS_ENABLED=false
CACHE_TTL_SECONDS=300

# Market Data Providers (fallback chain: Polygon → Alpha Vantage → YFinance)
YFINANCE_ENABLED=true
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_API_BASE_URL=https://api.massive.com
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
POLYGON_DAILY_LIMIT=1000
POLYGON_PER_MINUTE_LIMIT=5
ALPHA_VANTAGE_DAILY_LIMIT=25
TRADINGVIEW_ENABLED=false
TRADINGVIEW_API_KEY=
# FRED (Federal Reserve Economic Data) - https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
NEWS_API_KEY=

# LLM executive narratives (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Acceso multi-dispositivo (celular + PC) — elige una contraseña larga
DASHBOARD_ACCESS_TOKEN=elige_un_token_secreto_largo
# URL pública tras desplegar (opcional): https://nexbuy-ceo.fastapicloud.dev
PUBLIC_BASE_URL=

# Scheduler (US Eastern market hours)
MARKET_TIMEZONE=America/New_York
REPORT_TIMES=08:30,11:30,15:00,17:30

# Investment Director
AGENT_WEIGHTS_AUTO_CALIBRATE=true
MAX_CONCENTRATION_PCT=25.0

# Automation (Phase 3)
SCHEDULER_ENABLED=true
WATCHLIST_SCAN_INTERVAL_MINUTES=30
MEMORY_EVALUATION_DAYS=90
ALERT_COOLDOWN_HOURS=24

# Push notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=true
ALERT_WEBHOOK_URL=
PUSH_DAILY_TRADES=true

# Alpaca Trading + Market Data — compatible con https://github.com/alpacahq/cli
# Genera keys de la cuenta REAL (brokerage). NO las subas al repo.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=false
# Alternativa CLI: ALPACA_LIVE_TRADE=true fuerza LIVE (gana sobre ALPACA_PAPER)
ALPACA_LIVE_TRADE=true
# Trading base URL (vacío → https://api.alpaca.markets si LIVE)
ALPACA_BASE_URL=
# Market Data API
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
# iex = gratis (IEX); sip = todas las bolsas (requiere suscripción)
ALPACA_DATA_FEED=iex

# Risk Desk + macro (gestión de riesgo en recomendaciones y órdenes)
RISK_MAX_POSITION_PCT=35
RISK_MAX_SECTOR_PCT=40
RISK_MAX_GROSS_EXPOSURE_PCT=90
RISK_CASH_RESERVE_PCT=10
RISK_MAX_DAILY_LOSS_PCT=5
RISK_MAX_OPEN_POSITIONS=8
RISK_REQUIRE_STOP_LOSS=true
RISK_MIN_REWARD_RISK=1.2
RISK_OFF_SIZE_MULT=0.35
RISK_CRISIS_BLOCK_BUYS=true
# Autonomía: OFF por defecto. Paper primero.
# AUTO_EXECUTE_TRADES=true + AUTO_EXECUTE_LIVE=true solo si aceptas auto-órdenes LIVE
AUTO_EXECUTE_TRADES=false
AUTO_EXECUTE_LIVE=false
AUTO_EXECUTE_MAX_NOTIONAL=25
AUTO_EXECUTE_REQUIRE_MARKET_OPEN=true
AUTO_EXECUTE_PAPER_FIRST=true
# Autopilot programado (0 = solo manual vía POST /ops/autopilot/run o botón Autopilot)
AUTOPILOT_INTERVAL_MINUTES=0

# Lifecycle (trailing / time-stop / thesis → exit)
LIFECYCLE_ENABLED=true
LIFECYCLE_SCAN_INTERVAL_MINUTES=15
LIFECYCLE_TRAILING_PCT=0.08
LIFECYCLE_TIME_STOP_DAYS=10
LIFECYCLE_DEFAULT_STOP_PCT=0.08
LIFECYCLE_DEFAULT_TARGET_PCT=0.12
LIFECYCLE_AUTO_EXIT=true

# Reconciliación Alpaca ↔ DB
RECONCILE_INTERVAL_MINUTES=20
RECONCILE_AUTO_SYNC=true

# VaR / beta / sectores duros
RISK_MAX_VAR_PCT=8
RISK_MAX_PORTFOLIO_BETA=1.8
RISK_ENFORCE_SECTOR_CAP=true
RISK_ENFORCE_VAR_BETA=true

# Retry
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=1.5
